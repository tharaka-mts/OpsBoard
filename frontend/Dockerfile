FROM nginx:alpine

# Remove the default Nginx index.html files
RUN rm -rf /usr/share/nginx/html/*

# Copy the built frontend files generated by Jenkins (Yarn) to Nginx's serving directory
COPY dist/ /usr/share/nginx/html/

# Add a simple Nginx configuration to support Single Page Applications (SPA)
# This ensures React/Vue routers work perfectly when users refresh the page
RUN echo 'server { \
    listen 80; \
    location / { \
        root /usr/share/nginx/html; \
        index index.html index.htm; \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

# Expose port 80 for web traffic
EXPOSE 80

# Start Nginx when the container starts
CMD ["nginx", "-g", "daemon off;"]
