pipeline {
    agent any

    environment {
        // Local SonarQube environment variables
        SONAR_HOST_URL = "http://sonarqube:9000"
        // This credentials ID should match the token created in Jenkins referring to SonarQube token
        SONAR_TOKEN = credentials('sonar-token')
        NVD_API_KEY = credentials('nvd-api-key') 
        
        // Docker image tags
        BACKEND_IMAGE = "opsboard-backend:local"
        FRONTEND_IMAGE = "opsboard-frontend:local"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Backend Build & Test') {
            steps {
                dir('backend') {
                    sh '''
                        export SPRING_DATASOURCE_URL=jdbc:postgresql://postgres_backend:5432/opsboard
                        export SPRING_DATASOURCE_USERNAME=opsboarduser
                        export SPRING_DATASOURCE_PASSWORD=ops@123
                        mvn clean package
                    '''
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    sh '''
                        yarn install
                        yarn build
                    '''
                }
            }
        }

        stage('OWASP Dependency-Check') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    echo "Running OWASP Dependency-Check..."
                    sh 'dependency-check.sh --project "OpsBoard" --scan . --format HTML --out dependency-check-report --data /var/jenkins_home/.owasp --nvdApiKey ${NVD_API_KEY} --nvdApiDelay 20000 --disableOssIndex'
                }
            }
        }

        stage('SonarQube Scan') {
            steps {
                echo "Running SonarQube Scan..."
                // 'sonarqube' here refers to the name of the SonarQube server configured in Jenkins > Manage Jenkins > System
                withSonarQubeEnv('sonarqube') {
                    sh '''
                        # Point to the settings file inside the jenkins folder
                        sonar-scanner \
                          -Dproject.settings=jenkins/sonar-project.properties \
                          -Dsonar.host.url=${SONAR_HOST_URL} \
                          -Dsonar.login=${SONAR_TOKEN}
                    '''
                }
            }
        }

        stage('SonarQube Quality Gate') {
            steps {
                echo "Waiting for SonarQube Quality Gate..."
                timeout(time: 5, unit: 'MINUTES') {
                    // Requires a webhook configured in SonarQube pointing to:
                    // http://jenkins_local:8080/sonarqube-webhook/
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Backend Docker Image locally') {
            steps {
                dir('backend') {
                    sh "docker build -t ${BACKEND_IMAGE} ."
                }
            }
        }

        stage('Build Frontend Docker Image locally') {
            steps {
                dir('frontend') {
                    sh "docker build -t ${FRONTEND_IMAGE} ."
                }
            }
        }

        stage('Trivy filesystem scan') {
            steps {
                echo "Running Trivy Vulnerability Scan on filesystem..."
                sh 'trivy fs --no-progress .'
            }
        }

        stage('Trivy image scan') {
            steps {
                echo "Running Trivy Vulnerability Scan on built images..."
                sh "trivy image --no-progress ${BACKEND_IMAGE}"
                sh "trivy image --no-progress ${FRONTEND_IMAGE}"
            }
        }

        stage('Show local images') {
            steps {
                echo "Listing generated internal local docker images..."
                sh 'docker images | grep opsboard || true'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'dependency-check-report/*', allowEmptyArchive: true
            echo "CI pipeline completed."
        }
        success {
            echo "SUCCESS: Local CI pipeline finished successfully."
        }
        failure {
            echo "FAILED: Local CI pipeline failed."
        }
    }
}
