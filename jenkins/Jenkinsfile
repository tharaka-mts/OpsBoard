pipeline {
    agent { label 'opsboard-agent' }

    parameters {
        string(name: 'IMAGE_NAME_PREFIX', defaultValue: 'opsboard', description: 'Prefix for the Docker Image namespaces')
    }

    environment {
        // SonarQube environment variables
        SONAR_HOST_URL = "http://sonarqube:9000"
        SONAR_TOKEN = credentials('sonar-token')
        NVD_API_KEY = credentials('nvd-api-key')
        
        // ECR & Git configuration
        AWS_REGION = "us-east-1"
        APP_NAME = "${params.IMAGE_NAME_PREFIX}"
        IMAGE_TAG = "prod-${BUILD_NUMBER}"
        GITHUB_REPO_URL = "https://github.com/tharaka-mts/OpsBoard.git"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Backend Build & Test') {
            steps {
                dir('backend') {
                    sh '''
                        export SPRING_DATASOURCE_URL=jdbc:postgresql://postgres_backend:5432/opsboard
                        export SPRING_DATASOURCE_USERNAME=opsboarduser
                        export SPRING_DATASOURCE_PASSWORD=ops@123
                        mvn clean package
                    '''
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    sh '''
                        yarn install
                        yarn build
                    '''
                }
            }
        }

        stage('OWASP Dependency-Check') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    echo "Running OWASP Dependency-Check..."
                    sh 'dependency-check.sh --project "OpsBoard" --scan . --format HTML --out dependency-check-report --data /var/jenkins_home/.owasp --nvdApiKey ${NVD_API_KEY} --nvdApiDelay 20000 --disableOssIndex'
                }
            }
        }

        stage('SonarQube Scan') {
            steps {
                echo "Running SonarQube Scan..."
                withSonarQubeEnv('sonarqube') {
                    sh '''
                        sonar-scanner \
                          -Dproject.settings=jenkins/sonar-project.properties \
                          -Dsonar.host.url=${SONAR_HOST_URL} \
                          -Dsonar.login=${SONAR_TOKEN}
                    '''
                }
            }
        }

        stage('SonarQube Quality Gate') {
            steps {
                echo "Waiting for SonarQube Quality Gate..."
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build & Push to ECR') {
            steps {
                script {
                    echo "Authenticating with AWS ECR..."
                    // Fetch account ID dynamically via STS 
                    env.AWS_ACCOUNT_ID = sh(script: 'aws sts get-caller-identity --query Account --output text', returnStdout: true).trim()
                    env.ECR_REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                    
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"

                    echo "Building and tagging Backend Image..."
                    dir('backend') {
                        sh "docker build -t ${ECR_REGISTRY}/${APP_NAME}-backend:${IMAGE_TAG} ."
                        echo "Pushing Backend Image..."
                        sh "docker push ${ECR_REGISTRY}/${APP_NAME}-backend:${IMAGE_TAG}"
                    }

                    echo "Building and tagging Frontend Image..."
                    dir('frontend') {
                        sh "docker build -t ${ECR_REGISTRY}/${APP_NAME}-frontend:${IMAGE_TAG} ."
                        echo "Pushing Frontend Image..."
                        sh "docker push ${ECR_REGISTRY}/${APP_NAME}-frontend:${IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                echo "Scanning Images..."
                sh "trivy image --no-progress ${ECR_REGISTRY}/${APP_NAME}-backend:${IMAGE_TAG}"
                sh "trivy image --no-progress ${ECR_REGISTRY}/${APP_NAME}-frontend:${IMAGE_TAG}"
            }
        }

        stage('GitOps CD: Update Helm Manifests') {
            steps {
                echo "Updating helm/values.yaml with new tags for ArgoCD sync..."
                withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                    sh """
                        git config user.email "jenkins@opsboard.local"
                        git config user.name "Jenkins Pipeline"
                        
                        # Replace frontend and backend tag dynamically using sed
                        sed -i "s/tag: .*/tag: \\"${IMAGE_TAG}\\"/g" helm/values.yaml
                        sed -i "s/<AWS_ACCOUNT_ID>/${env.AWS_ACCOUNT_ID}/g" helm/values.yaml
                        
                        # Authenticate and push back to prod with [skip ci] to prevent loop
                        git add helm/values.yaml
                        git commit -m "[skip ci] CD: Update images to ${IMAGE_TAG}"
                        
                        git push https://${GIT_USER}:${GIT_PASS}@github.com/tharaka-mts/OpsBoard.git prod
                    """
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'dependency-check-report/*', allowEmptyArchive: true
        }
        success {
            echo "CI/CD Pipeline Successful."
            slackSend(
                color: 'good', 
                message: "✅ SUCCESS: OpsBoard Pipeline Build #${BUILD_NUMBER} completed successfully.\nDetails: ${env.BUILD_URL}",
                channel: '#opsboard-alerts',
                teamDomain: 'opsboard-workspace',
                tokenCredentialId: 'slack-token'
            )
        }
        failure {
            echo "CI/CD Pipeline Failed."
            slackSend(
                color: 'danger', 
                message: "❌ FAILURE: OpsBoard Pipeline Build #${BUILD_NUMBER} failed!\nSee Logs: ${env.BUILD_URL}",
                channel: '#opsboard-alerts',
                teamDomain: 'opsboard-workspace',
                tokenCredentialId: 'slack-token'
            )
        }
    }
}
